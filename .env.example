# =============================================================================
# Axy Web - Environment Variables
# Copy to .env and fill in required values
# =============================================================================

# ─── Required ───────────────────────────────────────────
# Database (PostgreSQL in production, SQLite in dev)
DB_USER=axy
DB_PASSWORD=change_me_to_random_string
DATABASE_URL=postgres://axy:change_me_to_random_string@db:5432/axy

# JWT secret for auth tokens (min 32 chars, auto-generated by install script)
JWT_SECRET=change_me_to_random_string_min_32_chars

# ─── Optional: GitHub OAuth ─────────────────────────────
# Enables "Continue with GitHub" on login page
# Create at: https://github.com/settings/developers
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# ─── Optional: Ports ────────────────────────────────────
# SERVER_PORT=3456
# WEB_PORT=3457

# ─── Optional: CORS ─────────────────────────────────────
# CORS_ORIGINS=http://localhost:3457

# ─── Optional: Claude CLI ───────────────────────────────
# Path to claude CLI binary (default: claude in PATH)
# CLAUDE_PATH=claude

# ─── Note ───────────────────────────────────────────────
# Supabase is NOT required. Axy has built-in local auth.
# On first visit, you'll create an admin account via the setup wizard.
# GitHub OAuth is optional - you can always use email/password login.
