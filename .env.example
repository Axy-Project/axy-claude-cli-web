# Database
DB_USER=axy
DB_PASSWORD=your_secure_password_here
DB_PORT=5432
DATABASE_URL=postgres://axy:your_secure_password_here@localhost:5432/axy

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_KEY=your_service_key

# Auth
JWT_SECRET=your_jwt_secret_min_32_chars

# GitHub OAuth
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Google OAuth (via Supabase)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Server
SERVER_PORT=3456
PROJECTS_DIR=/data/projects

# Web
WEB_PORT=3457
PUBLIC_API_URL=http://localhost:3456
PUBLIC_WS_URL=ws://localhost:3456
NEXT_PUBLIC_API_URL=http://localhost:3456
NEXT_PUBLIC_WS_URL=ws://localhost:3456
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
